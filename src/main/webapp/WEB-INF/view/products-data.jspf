<%@ page import="java.util.*" %>
<%--
  Sample catalog for the frontend demo.
  In a real build this would come from a database / service layer —
  here it's a hardcoded List so every page can loop over it with JSTL
  <c:forEach> without needing a servlet or backend.

  Fields per product, in order:
  0 id | 1 name | 2 category | 3 origin | 4 roastDate | 5 process |
  6 weightGrams | 7 price | 8 oldPrice (or "") | 9 tone (tone-1..4) |
  10 glyph (short mark for the card) | 11 description
--%>
<%
    List<String[]> productList = new ArrayList<String[]>();
