    productList.add(new String[]{"5","Chemex Six-Cup","Brew Gear","Borosilicate glass","","","","48.00","","tone-1","CX","The classic hourglass carafe. One piece of glass, no seams, brews for a whole table."});
    productList.add(new String[]{"6","Field Grinder","Brew Gear","Steel burr, hand crank","","","","89.00","98.00","tone-2","FG","40mm conical steel burrs and 31 click stops, from espresso-fine to French-press-coarse."});
